# Stripe Configuration (Kreditkarten-Zahlungen)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# PayPal Configuration
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
# Für Live-Betrieb ändern zu: https://api-m.paypal.com

# Email Configuration (SMTP)
# Für MailerLite:
SMTP_HOST=smtp.mailerlite.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@domain.com
SMTP_PASS=your-mailerlite-api-key
SMTP_FROM="Dein Name" <noreply@yourdomain.com>

# Für Gmail (Alternative):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Application Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Für Live-Betrieb ändern zu: https://deinewebsite.de
NODE_ENV=development

# Database Configuration (Optional)
DATABASE_URL=sqlite:./crm.db

# Social Media Tracking (Optional)
FACEBOOK_PIXEL_ID=your-facebook-pixel-id
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# CRM Configuration (Optional)
CRM_WEBHOOK_URL=https://your-crm.com/webhook
CRM_API_KEY=your-crm-api-key

# Security
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here
